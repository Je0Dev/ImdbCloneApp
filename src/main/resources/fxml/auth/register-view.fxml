<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.papel.imdb_clone.controllers.authentication.AuthController"
            style="-fx-background-color: #0f0f0f;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <center>
        <StackPane fx:id="registerContainer">
            <!-- Register Container -->
            <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #1a1a1a; -fx-padding: 40; -fx-background-radius: 10;" prefWidth="400">
                <!-- Logo -->
                <Label text="IMDb Clone" style="-fx-text-fill: #f5c518; -fx-font-size: 36px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" />

                <!-- Registration Form -->
                <VBox alignment="CENTER" spacing="15" style="-fx-padding: 0 20 20 20;" prefWidth="400">
                    <Label text="Create Account" style="-fx-text-fill: #ffffff; -fx-font-size: 24px; -fx-font-weight: bold;" />

                    <VBox spacing="5">
                        <Label text="First Name" style="-fx-text-fill: #ffffff;" />
                        <TextField fx:id="firstNameField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Last Name" style="-fx-text-fill: #ffffff;" />
                        <TextField fx:id="lastNameField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Username" style="-fx-text-fill: #ffffff;" />
                        <TextField fx:id="registerUsernameField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Email" style="-fx-text-fill: #ffffff;" />
                        <TextField fx:id="emailField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <Label text="Password" style="-fx-text-fill: #ffffff;" />
                            <Button onAction="#toggleRegisterPasswordVisibility" style="-fx-background-color: transparent; -fx-text-fill: #f5c518; -fx-underline: true; -fx-cursor: hand; -fx-padding: 0 0 0 5;" text="Show" />
                        </HBox>
                        <PasswordField fx:id="registerPasswordField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                        <TextField fx:id="registerPasswordVisibleField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" visible="false" />
                    </VBox>

                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <Label text="Confirm Password" style="-fx-text-fill: #ffffff;" />
                        </HBox>
                        <PasswordField fx:id="confirmPasswordField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" />
                        <TextField fx:id="confirmPasswordVisibleField" style="-fx-pref-width: 300; -fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #666666; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;" visible="false" />
                    </VBox>

                    <Button fx:id="registerButton" text="Create Account" onAction="#handleRegister" style="-fx-background-color: #f5c518; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-pref-width: 300; -fx-padding: 12; -fx-cursor: hand; -fx-background-radius: 5; -fx-margin: 10 0 0 0;" />

                    <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
                        <Label text="Already have an account?" style="-fx-text-fill: #999999;" />
                        <Button text="Sign in" onAction="#navigateToLogin" style="-fx-background-color: transparent; -fx-text-fill: #f5c518; -fx-underline: true; -fx-cursor: hand; -fx-padding: 0;" />
                    </HBox>

                    <Label fx:id="errorLabel" style="-fx-text-fill: #ff4444; -fx-padding: 10 0 0 0;" visible="false" />
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
